# Backend environment variables
# Copy to .env and fill in real values. Never commit .env.
# All vars are validated by src/config/env.ts (Zod) at startup; missing or
# invalid values fail fast.

# Postgres connection. Matches docker-compose.yml defaults for local dev.
DATABASE_URL="postgresql://dop:dop_secret@localhost:5432/dop_compliance?schema=public"

# JWT secret. Must be ≥32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
JWT_SECRET=""

# Token lifetime (e.g. "15m", "7d"). Access tokens should be short.
JWT_EXPIRES_IN="15m"

# HTTP server port.
PORT="3000"

# Comma-separated list of allowed CORS origins. No wildcards.
CORS_ORIGIN="http://localhost:5173"

# Logging level: error | warn | info | debug
LOG_LEVEL="info"
